<Window x:Class="Psytest.UI.Windows.PsychologistModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Psytest.UI.Windows"
        mc:Ignorable="d"
        Icon="/Resources/Images/icon.png" Topmost="True"
        Title="Переход в режим администратора" Height="150" Width="420" WindowStartupLocation="CenterScreen"
        MinHeight="150" MinWidth="420" MaxHeight="150" MaxWidth="420" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Код:" HorizontalAlignment="Right" FontSize="22"/>
        
        <PasswordBox x:Name="PasswordBoxCode" Grid.Row="0" Grid.Column="1" Width="285" HorizontalAlignment="Left"
                     Margin="15, 0, 15, 0" Height="40" MaxLength="50" HorizontalContentAlignment="Left"/>
        
        <Button x:Name="ButtonEnter" Grid.Row="3" Grid.ColumnSpan="2" Content="Войти" Click="ButtonEnter_Click"/>
    </Grid>
</Window>
